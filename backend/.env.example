# Copy to .env and fill in real values. Never commit .env to git.

# PostgreSQL connection — must match setup-db.sql and docker-compose POSTGRES_PASSWORD
DATABASE_URL="postgresql://electromall:STRONG_PASSWORD_HERE@localhost:5432/electromall_vendors"

# JWT secret — minimum 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET="replace-with-output-of-openssl-rand-base64-48"

JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development

# Set to your actual frontend origin in production (no trailing slash)
CORS_ORIGIN="http://localhost:3000"
